# Copy to .env and adjust. Never commit .env.
APP_NAME=SubLedger
DEBUG=false
DATABASE_URL=postgresql+psycopg2://subledger:subledger@localhost:5432/subledger
# Comma-separated origins allowed to call the API from a browser
CORS_ORIGINS=http://localhost:5173

# Auth (Phase 9): change both for anything beyond local development
ADMIN_API_KEY=dev-admin-key
JWT_SECRET=dev-jwt-secret-change-me
JWT_EXPIRES_MINUTES=720
